# Copy to .env and edit. Never commit .env or cookies/.
TZ=Asia/Jakarta
X_HANDLE=@your_id_account
X_TARGET_MODE=id
X_COOKIE_PERSISTENT=./cookies/x_cookies_id.json
X_COOKIE_FILE=/tmp/x_cookies_id.json
PYTHON=python3
APP_DIR=../core
HELPER_DIR=../scripts

# Optional Telegram notifications
# Export TELEGRAM_BOT_TOKEN in your shell or put it in a private .env (do not commit it).
X_TG_CHAT=
X_TG_THREAD=

# Targeting/cadence knobs
X_FORYOU_PERCENT=50
X_MIN_VIEWS=20000
X_ID_MIN_VIEWS=20000
X_THROTTLE_MIN_GAP=900
